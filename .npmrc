# Fail local (non-frozen) installs on UNMET peer dependencies instead of
# resolving them with a warning. Defence-in-depth for everyday installs.
#
# NOTE: this is NOT the gate for the react/react-dom major split. With
# autoInstallPeers on, a react-dom 19 bump resolves against react 18 and is
# baked into the lockfile as "satisfied", so there is no unmet peer to flag —
# and `--frozen-lockfile` never evaluates peers at all. That class is caught by
# scripts/check-react-pairing.mjs, wired into the ci build job.
strict-peer-dependencies=true
